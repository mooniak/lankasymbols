# buildTTF: Build a TTF from a source file
rule buildTTF
  command = $
      /Users/pathumego/src/github/mooniak/font-repos/mooniak-font-tools/.venv/bin/python3.12 $
      -m gftools.builder.jobrunner fontmake --output-path $out -o ttf $
      $fontmake_type $in $args $stamp
  description = buildTTF

# autohint: Run gftools-autohint
rule autohint
  command = $
      /Users/pathumego/src/github/mooniak/font-repos/mooniak-font-tools/.venv/bin/python3.12 $
      -m gftools.builder.jobrunner gftools-autohint $args -o $out $in $stamp
  description = autohint

# fix: Run gftools-fix
rule fix
  command = $
      /Users/pathumego/src/github/mooniak/font-repos/mooniak-font-tools/.venv/bin/python3.12 $
      -m gftools.builder.jobrunner gftools-fix-font -o $out $args $in $stamp
  description = fix

# compress: Compress to webfont
rule compress
  command = $
      /Users/pathumego/src/github/mooniak/font-repos/mooniak-font-tools/.venv/bin/python3.12 $
      -m gftools.builder.jobrunner fonttools ttLib.woff2 compress -o $out $
      $in $stamp
  description = compress

# buildOTF: Build a OTF from a source file
rule buildOTF
  command = $
      /Users/pathumego/src/github/mooniak/font-repos/mooniak-font-tools/.venv/bin/python3.12 $
      -m gftools.builder.jobrunner fontmake --output-path $out -o otf $
      $fontmake_type $in $args $stamp
  description = buildOTF

# copy: Copy a file
rule copy
  command = $
      /Users/pathumego/src/github/mooniak/font-repos/mooniak-font-tools/.venv/bin/python3.12 $
      -m gftools.builder.jobrunner cp $in $out $stamp
  description = copy

# Generating /var/folders/kq/qnbdv5c51zbc56xfr_dtzs680000gn/T/tmply82s1r6
build /var/folders/kq/qnbdv5c51zbc56xfr_dtzs680000gn/T/tmply82s1r6: $
    buildTTF LankaSymbols.ufo
  operation = buildTTF
  args = --filter ...  --filter FlattenComponentsFilter --filter $
      DecomposeTransformedComponentsFilter
  fontmake_type = -u
  fontmake_args =  --verbose WARNING 
# Generating /var/folders/kq/qnbdv5c51zbc56xfr_dtzs680000gn/T/tmp3nrx1ym1
build /var/folders/kq/qnbdv5c51zbc56xfr_dtzs680000gn/T/tmp3nrx1ym1: $
    buildOTF LankaSymbols.ufo
  operation = buildOTF
  args = --filter ...  --filter FlattenComponentsFilter --filter $
      DecomposeTransformedComponentsFilter
  fontmake_type = -u
  fontmake_args =  --verbose WARNING 
# Generating ../fonts/webfonts/LankaSymbols.woff2
build ../fonts/webfonts/LankaSymbols.woff2: compress $
    ../fonts/ttf/LankaSymbols.ttf
  operation = compress
# Generating /var/folders/kq/qnbdv5c51zbc56xfr_dtzs680000gn/T/tmpz7bgyime
build /var/folders/kq/qnbdv5c51zbc56xfr_dtzs680000gn/T/tmpz7bgyime: $
    autohint /var/folders/kq/qnbdv5c51zbc56xfr_dtzs680000gn/T/tmply82s1r6
  operation = autohint
  args = --fail-ok 
# Generating ../fonts/ttf/LankaSymbols.ttf
build ../fonts/ttf/LankaSymbols.ttf: fix $
    /var/folders/kq/qnbdv5c51zbc56xfr_dtzs680000gn/T/tmpz7bgyime
  operation = fix
  args = 
# Generating ../fonts/otf/LankaSymbols.otf
build ../fonts/otf/LankaSymbols.otf: fix $
    /var/folders/kq/qnbdv5c51zbc56xfr_dtzs680000gn/T/tmp3nrx1ym1
  operation = fix
  args = 
default ../fonts/webfonts/LankaSymbols.woff2 ../fonts/otf/LankaSymbols.otf
